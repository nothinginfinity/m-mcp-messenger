    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "ethers": "^6.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "keywords": ["mcp", "mobile", "ai", "messaging", "ethereum", "identity", "local-first"],
  "license": "MIT"
}
