{
  "name": "m-mcp-messenger",
  "version": "0.1.0",
  "description": "AI-to-AI email system built on m-mcp. Ethereum-style identity, signed envelopes, Bitcoin Zero cognitive work tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
